{
  "name": "sai-laptop-rms",
  "private": true,
  "description": "Sai Laptop & Computer Gallery - Repair Management System",
  "author": "Sai Laptop RMS",
  "version": "1.5.1",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:electron": "concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "vite build",
    "build:electron": "scripts\\build.ps1",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "build": {
    "appId": "com.sailaptop.rms",
    "productName": "SaiLaptopRMS",
    "directories": {
      "output": "dist"
    },
    "publish": null,
    "files": [
      "dist/**/*",
      "!dist/win-unpacked/**/*",
      "!dist/*.exe",
      "!dist/*.7z",
      "!dist/*.blockmap",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "shortcutName": "Sai Laptop RMS",
      "guid": "com.sailaptop.rms",
      "installerIcon": "public/logo.ico",
      "installerHeaderIcon": "public/logo.ico",
      "deleteAppDataOnUninstall": false
    }
  },
  "dependencies": {
    "axios": "^1.17.0",
    "html-to-image": "^1.11.13",
    "jsbarcode": "^3.12.3",
    "nanoid": "^3.3.15",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "vite-plugin-pwa": "^1.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-packager": "^17.1.2",
    "pkg": "^5.8.1",
    "png-to-ico": "^3.0.1",
    "vite": "^8.0.12",
    "wait-on": "^9.0.10"
  }
}
